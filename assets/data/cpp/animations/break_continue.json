{
  "animationId": "cpp_break_continue",
  "itemId": "1.5.9",
  "title": "break 与 continue",
  "description": "演示 for 循环中 break 提前退出和 continue 跳过当前轮的区别",
  "initialState": {
    "variables": [],
    "containers": [],
    "output": ""
  },
  "steps": [
    {
      "step": 1,
      "title": "循环开始",
      "description": "for 循环从 i=1 到 i<=6，目标是找出第一个能被 4 整除的数",
      "codeLine": "for (int i = 1; i <= 6; i++) {",
      "highlights": ["i = 1", "i <= 6"],
      "state": {
        "variables": [
          {"name": "i", "value": "1", "note": "初始化"}
        ],
        "containers": [],
        "output": ""
      }
    },
    {
      "step": 2,
      "title": "i=1：不满足条件",
      "description": "1 % 4 != 0，不触发 break，输出 1，继续下一轮",
      "codeLine": "if (i % 4 == 0) break; cout << i << \" \";",
      "highlights": ["i % 4 == 0"],
      "state": {
        "variables": [
          {"name": "i", "value": "1", "note": "1%4=1 ≠ 0，不 break"}
        ],
        "containers": [],
        "output": "1 "
      }
    },
    {
      "step": 3,
      "title": "i=2、i=3：正常输出",
      "description": "2%4=2 ≠ 0，3%4=3 ≠ 0，均正常输出",
      "codeLine": "if (i % 4 == 0) break; cout << i << \" \";",
      "highlights": ["i % 4 == 0"],
      "state": {
        "variables": [
          {"name": "i", "value": "3", "note": "2%4≠0, 3%4≠0"}
        ],
        "containers": [],
        "output": "1 2 3 "
      }
    },
    {
      "step": 4,
      "title": "i=4：触发 break",
      "description": "4 % 4 == 0 为 true，执行 break，循环立即终止，4 不会被输出",
      "codeLine": "if (i % 4 == 0) break;",
      "highlights": ["break"],
      "state": {
        "variables": [
          {"name": "i", "value": "4", "note": "4%4=0 → break! 退出循环"}
        ],
        "containers": [],
        "output": "1 2 3 "
      }
    },
    {
      "step": 5,
      "title": "对比 continue",
      "description": "如果用 continue 替代 break，i=4 时会跳过本次输出但不退出循环，5 和 6 仍会输出",
      "codeLine": "// 若用 continue: 跳过本轮，继续下一轮",
      "highlights": ["continue"],
      "state": {
        "variables": [
          {"name": "i", "value": "6", "note": "continue 不退出循环"}
        ],
        "containers": [],
        "output": "1 2 3 5 6 "
      }
    }
  ]
}
