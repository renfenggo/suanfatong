          {"name": "y (add)", "value": "5", "note": ""},
          {"name": "x + y", "value": "8", "note": "返回值"}
        ],
        "containers": [],
        "output": ""
      }
    },
    {
      "step": 4,
      "title": "返回 main，接收返回值",
      "description": "add 函数返回 8，程序回到 main。返回值赋给 result，形参 x 和 y 被销毁",
