            "note": "自动升序排列"
          }
        ],
        "output": ""
      }
    },
    {
      "step": 3,
      "title": "插入重复元素",
      "description": "插入已存在的 5，set 会忽略重复值，size 不变",
      "codeLine": "s.insert(5);",
      "highlights": ["insert"],
      "state": {
        "variables": [
          {"name": "s.size()", "value": "3", "note": "不变，重复被忽略"}
        ],
        "containers": [
          {
            "name": "s",
            "type": "set",
            "values": ["3", "5", "8"],
