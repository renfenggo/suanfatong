            "note": "5 已存在，不重复插入"
          }
        ],
        "output": ""
      }
    },
    {
      "step": 4,
      "title": "查找元素",
      "description": "用 count 检查元素是否存在，返回 0 或 1",
      "codeLine": "cout << s.count(5) << \" \" << s.count(7);",
      "highlights": ["count"],
      "state": {
        "variables": [
          {"name": "s.count(5)", "value": "1", "note": "存在"},
          {"name": "s.count(7)", "value": "0", "note": "不存在"}
