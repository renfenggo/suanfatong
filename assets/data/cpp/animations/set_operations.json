        "containers": [
          {
            "name": "s",
            "type": "set",
            "values": ["3", "5", "8"],
            "activeIndex": 1,
            "note": "查找 5 → 找到"
          }
        ],
        "output": "1 0"
      }
    },
    {
      "step": 5,
      "title": "遍历输出",
      "description": "范围 for 遍历 set，输出一定是升序的",
