          }
        ],
        "output": ""
      }
    },
    {
      "step": 3,
      "title": "遍历输出",
      "description": "排序后遍历输出，元素从小到大",
      "codeLine": "for (int i = 0; i < n; i++) cout << a[i] << \" \";",
      "highlights": ["cout"],
      "state": {
        "variables": [
          {"name": "n", "value": "5", "note": ""}
        ],
        "containers": [
          {
            "name": "a",
            "type": "array",
