{
  "animationId": "cpp_type_conversion",
  "itemId": "1.3.17",
  "title": "类型转换",
  "description": "演示隐式类型转换和显式类型转换（强制转换），重点展示整数除法的问题",
  "initialState": {
    "variables": [],
    "containers": [],
    "output": ""
  },
  "steps": [
    {
      "step": 1,
      "title": "整数除法的问题",
      "description": "两个 int 做除法，结果还是 int，小数部分被截断。7 / 2 的结果是 3 而不是 3.5。",
      "codeLine": "int a = 7, b = 2;\ncout << a / b;",
      "highlights": ["a / b"],
      "state": {
        "variables": [
          {"name": "a", "value": "7", "note": "int"},
          {"name": "b", "value": "2", "note": "int"}
        ],
        "containers": [],
        "output": "3"
      }
    },
    {
      "step": 2,
      "title": "隐式类型转换",
      "description": "当 int 和 double 混合运算时，int 会自动提升为 double。这里 a 变成 7.0，7.0 / 2.0 = 3.5。",
      "codeLine": "double c = a / 2.0;\ncout << c;",
      "highlights": ["2.0", "c"],
      "state": {
        "variables": [
          {"name": "a", "value": "7", "note": "int"},
          {"name": "b", "value": "2", "note": "int"},
          {"name": "c", "value": "3.5", "note": "double，自动提升为浮点运算"}
        ],
        "containers": [],
        "output": "3\n3.5"
      }
    },
    {
      "step": 3,
      "title": "显式强制转换 (double)",
      "description": "用 (double)a 把 int 变量 a 强制转换为 double。这样 a / b 就变成了 7.0 / 2.0 = 3.5，得到正确的小数结果。",
      "codeLine": "cout << (double)a / b;",
      "highlights": ["(double)", "a"],
      "state": {
        "variables": [
          {"name": "a", "value": "7", "note": "int，值不变"},
          {"name": "b", "value": "2", "note": "int，值不变"},
          {"name": "c", "value": "3.5", "note": "double"}
        ],
        "containers": [],
        "output": "3\n3.5\n3.5"
      }
    },
    {
      "step": 4,
      "title": "显式强制转换 (int)",
      "description": "反过来，(int) 可以把 double 截断为 int。3.9 变成 3，小数部分直接丢弃，不是四舍五入。",
      "codeLine": "double pi = 3.9;\ncout << (int)pi;",
      "highlights": ["(int)", "pi"],
      "state": {
        "variables": [
          {"name": "a", "value": "7", "note": "int"},
          {"name": "b", "value": "2", "note": "int"},
          {"name": "c", "value": "3.5", "note": "double"},
          {"name": "pi", "value": "3.9", "note": "double，值不变"}
        ],
        "containers": [],
        "output": "3\n3.5\n3.5\n3"
      }
    }
  ]
}
